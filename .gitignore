# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
fun_sheep-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# esbuild and tailwind standalone binaries (downloaded by mix assets.setup)
esbuild-linux-x64
tailwind-linux-x64
esbuild-darwin-arm64
esbuild-darwin-x64
tailwind-darwin-arm64
tailwind-darwin-x64

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/node_modules/
/assets/node_modules/
/test/e2e/node_modules/

# Playwright
/test/e2e/test-results/
/test/e2e/playwright-report/
/test/e2e/screenshots/
/test/visual/
/test-results/
/screenshots/

# Runtime logs
/log/
/logs/

# Releases (built artifacts)
/rel/

# File uploads (local dev + prod uses GCS)
/priv/uploads/
/priv/static/uploads/

# Ingestion cache (NCES, IPEDS, NEIS, GIAS, ACARA raw downloads)
/priv/cache/

# Claude Code scheduled task lock
/.claude/scheduled_tasks.lock

# Claude Code parallel-agent worktrees (local scratch, already in .gcloudignore)
/.claude/worktrees/

# Environment
.env
.env.local
.env.production
.env.prod
.env.credentials


# Runtime pid files from dev-app.sh
.dev-pids/
