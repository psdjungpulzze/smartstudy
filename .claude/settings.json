{
  "permissions": {
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Read(**/*)",
      "Glob(**/*)",
      "Grep(**/*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(mix ecto.drop:*)",
      "Bash(mix ecto.reset:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Edit(package.json)",
      "Edit(package-lock.json)"
    ],
    "deny": [
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(**/credentials*)",
      "Write(**/secrets/**)",
      "Write(**/.env.credentials)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(**/.env.credentials)",
      "Read(**/.env.*.local)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/.aws/**)",
      "Read(**/.config/gcloud/**)",
      "Read(**/.docker/config.json)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/.bash_history)",
      "Read(**/.zsh_history)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash(mix compile*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/ensure-server.sh"
          }
        ]
      },
      {
        "matcher": "Write(**/*.ex)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/ensure-server.sh"
          }
        ]
      },
      {
        "matcher": "Write(**/*.heex)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/ensure-server.sh"
          }
        ]
      },
      {
        "matcher": "Edit(**/live/**/*.ex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Edit(**/*.heex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Edit(**/components/**/*.ex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Write(**/live/**/*.ex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Write(**/*.heex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Write(**/components/**/*.ex)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🛑 STOP: UI file modified. You MUST run the visual-tester Playwright agent BEFORE reporting this change to the user.'"
          }
        ]
      },
      {
        "matcher": "Write(*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.tsx)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.js)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.jsx)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.json)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "python -m black \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write(*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/bash-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write(.env*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  WARNING: Modifying environment file. Ensure no secrets are being committed.'"
          }
        ]
      },
      {
        "matcher": "Write(**/production/**)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  WARNING: Modifying production configuration file.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PROJECT_ROOT='$(pwd) >> $CLAUDE_ENV_FILE 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
    "EDITOR": "code",
    "NODE_ENV": "development"
  },
  "attribution": {
    "commit": "Generated with AI assistance\n\nCo-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "Generated with AI assistance"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
