# =============================================================================
# FunSheep Production Deployment Config
# =============================================================================
# Copy to .env.prod (gitignored) and fill in values.
# Consumed by scripts/deploy/deploy-prod.sh
# =============================================================================

# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=funsheep-prod
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=funsheep-api
DB_INSTANCE=funsheep-db

# Public hostname for the app
PHX_HOST=funsheep.com

# -----------------------------------------------------------------------------
# Interactor Platform — get these from the Interactor GCP deploy session
# -----------------------------------------------------------------------------
# Cloud Run URLs of each Interactor service
INTERACTOR_URL=https://account-server-XXXX.a.run.app
INTERACTOR_CORE_URL=https://interactor-XXXX.a.run.app
INTERACTOR_UKB_URL=https://service-knowledge-base-XXXX.a.run.app
INTERACTOR_UDB_URL=https://user-database-XXXX.a.run.app

# Organization slug registered in the prod account-server
INTERACTOR_ORG_NAME=studysmart

# OAuth client credentials for the FunSheep application registered in the
# prod account-server admin panel (must have redirect URI
# https://<PHX_HOST>/auth/callback)
INTERACTOR_CLIENT_ID=app_XXXXXXXXXXXXXXXXXXXX
INTERACTOR_CLIENT_SECRET=sec_XXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Google Cloud Vision — OCR for uploaded materials
# -----------------------------------------------------------------------------
# API key for the Cloud Vision API. Pushed to Secret Manager as
# `google-vision-api-key` and injected into Cloud Run as GOOGLE_VISION_API_KEY.
# Without this, every OCR call returns HTTP 400 and uploaded materials end up
# in `:failed` status. Get the value from .env.credentials (dev) or rotate via
# the GCP console.
GOOGLE_VISION_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Google Cloud Storage — user uploads
# -----------------------------------------------------------------------------
# Created by scripts/deploy/gcs-setup.sh. Cloud Run's filesystem is ephemeral
# and per-instance, so uploads MUST go to GCS in production.
GCS_BUCKET=funsheep-uploads-prod
# Service account the Cloud Run service runs as. Must have
# roles/storage.objectAdmin on the bucket (bound automatically by gcs-setup.sh).
GCS_SERVICE_ACCOUNT=funsheep-storage@funsheep-prod.iam.gserviceaccount.com
